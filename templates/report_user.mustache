{{!
    @template mod_fastpix/report_user

    Per-user watch report: one student across this course's FastPix activities.

    Context variables required for this template:
    * cmid int
    * studentname string
    * backurl string
    * downloadurl string
    * hasrows bool
    * rows array
}}
<div class="fastpix-report fastpix-report-user" data-cmid="{{cmid}}">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <a class="btn btn-link p-0" href="{{backurl}}">&laquo; {{#str}}report_backtovideo, mod_fastpix{{/str}}</a>
        <a class="btn btn-secondary btn-sm" href="{{downloadurl}}">{{#str}}report_downloadcsv, mod_fastpix{{/str}}</a>
    </div>

    <h3 class="h5 mb-3">{{#str}}report_userheading, mod_fastpix, {{studentname}}{{/str}}</h3>

    {{#hasrows}}
    <div class="table-responsive">
        <table class="table table-striped table-hover fastpix-report-table">
            <thead>
                <tr>
                    <th scope="col">{{#str}}report_col_activity, mod_fastpix{{/str}}</th>
                    <th scope="col">{{#str}}report_col_watchpercent, mod_fastpix{{/str}}</th>
                    <th scope="col">{{#str}}report_col_watchtime, mod_fastpix{{/str}}</th>
                    <th scope="col">{{#str}}report_col_milestones, mod_fastpix{{/str}}</th>
                    <th scope="col">{{#str}}report_col_completed, mod_fastpix{{/str}}</th>
                    <th scope="col">{{#str}}report_col_lastposition, mod_fastpix{{/str}}</th>
                    <th scope="col">{{#str}}report_col_seeks, mod_fastpix{{/str}}</th>
                    <th scope="col">{{#str}}report_col_fraud, mod_fastpix{{/str}}</th>
                </tr>
            </thead>
            <tbody>
            {{#rows}}
                <tr>
                    <td><a href="{{activityurl}}">{{activityname}}</a></td>
                    <td>{{watchpercent}}%</td>
                    <td>{{watchtime}}</td>
                    <td>{{milestones}}</td>
                    <td>
                        {{#completed}}<span class="badge text-bg-success">{{#str}}yes{{/str}}</span>{{/completed}}
                        {{^completed}}<span class="text-muted">&mdash;</span>{{/completed}}
                    </td>
                    <td>{{lastposition}}</td>
                    <td>{{seeks}}</td>
                    <td>
                        {{#hasfraud}}<span class="badge text-bg-warning">{{fraudcount}}</span> <span class="text-muted">{{fraudreason}}</span>{{/hasfraud}}
                        {{^hasfraud}}0{{/hasfraud}}
                    </td>
                </tr>
            {{/rows}}
            </tbody>
        </table>
    </div>
    {{/hasrows}}
    {{^hasrows}}
    <div class="alert alert-info">{{#str}}report_nouserattempts, mod_fastpix{{/str}}</div>
    {{/hasrows}}
</div>
