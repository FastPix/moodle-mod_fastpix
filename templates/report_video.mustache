{{!
    @template mod_fastpix/report_video

    Per-video (class) watch report: summary strip + engagement curve + table.

    Context variables required for this template:
    * cmid int
    * viewers int
    * avgpercent int
    * completionrate int
    * hasdropoff bool
    * dropofflabel string
    * dropoffpct int
    * chart string (rendered chart HTML, trusted)
    * downloadurl string
    * hasrows bool
    * rows array
}}
<div class="fastpix-report" data-cmid="{{cmid}}">
    <div class="fastpix-report-summary">
        <div class="fastpix-report-stat">
            <div class="fastpix-report-stat-value">{{viewers}}</div>
            <div class="fastpix-report-stat-label">{{#str}}report_uniqueviewers, mod_fastpix{{/str}}</div>
        </div>
        <div class="fastpix-report-stat">
            <div class="fastpix-report-stat-value">{{avgpercent}}%</div>
            <div class="fastpix-report-stat-label">{{#str}}report_avgwatch, mod_fastpix{{/str}}</div>
        </div>
        <div class="fastpix-report-stat">
            <div class="fastpix-report-stat-value">{{completionrate}}%</div>
            <div class="fastpix-report-stat-label">{{#str}}report_completionrate, mod_fastpix{{/str}}</div>
        </div>
        {{#hasdropoff}}
        <div class="fastpix-report-stat">
            <div class="fastpix-report-stat-value">{{dropofflabel}}</div>
            <div class="fastpix-report-stat-label">{{#str}}report_biggestdropoff, mod_fastpix{{/str}} (&minus;{{dropoffpct}}%)</div>
        </div>
        {{/hasdropoff}}
    </div>

    {{#chart}}
    <div class="card mb-3">
        <div class="card-body">
            <h3 class="h6">{{#str}}report_engagement, mod_fastpix{{/str}}</h3>
            {{{chart}}}
        </div>
    </div>
    {{/chart}}

    <div class="d-flex justify-content-end mb-2">
        <a class="btn btn-secondary btn-sm" href="{{downloadurl}}">{{#str}}report_downloadcsv, mod_fastpix{{/str}}</a>
    </div>

    {{#hasrows}}
    <div class="table-responsive">
        <table class="table table-striped table-hover fastpix-report-table">
            <thead>
                <tr>
                    <th scope="col">{{#str}}report_col_student, mod_fastpix{{/str}}</th>
                    <th scope="col">{{#str}}report_col_watchpercent, mod_fastpix{{/str}}</th>
                    <th scope="col">{{#str}}report_col_watchtime, mod_fastpix{{/str}}</th>
                    <th scope="col">{{#str}}report_col_milestones, mod_fastpix{{/str}}</th>
                    <th scope="col">{{#str}}report_col_completed, mod_fastpix{{/str}}</th>
                    <th scope="col">{{#str}}report_col_lastposition, mod_fastpix{{/str}}</th>
                    <th scope="col">{{#str}}report_col_seeks, mod_fastpix{{/str}}</th>
                    <th scope="col">{{#str}}report_col_fraud, mod_fastpix{{/str}}</th>
                </tr>
            </thead>
            <tbody>
            {{#rows}}
                <tr>
                    <td><a href="{{userurl}}">{{studentname}}</a></td>
                    <td>{{watchpercent}}%</td>
                    <td>{{watchtime}}</td>
                    <td>{{milestones}}</td>
                    <td>
                        {{#completed}}<span class="badge text-bg-success">{{#str}}yes{{/str}}</span>{{/completed}}
                        {{^completed}}<span class="text-muted">&mdash;</span>{{/completed}}
                    </td>
                    <td>{{lastposition}}</td>
                    <td>{{seeks}}</td>
                    <td>
                        {{#hasfraud}}<span class="badge text-bg-warning">{{fraudcount}}</span> <span class="text-muted">{{fraudreason}}</span>{{/hasfraud}}
                        {{^hasfraud}}0{{/hasfraud}}
                    </td>
                </tr>
            {{/rows}}
            </tbody>
        </table>
    </div>
    {{/hasrows}}
    {{^hasrows}}
    <div class="alert alert-info">{{#str}}report_noattempts, mod_fastpix{{/str}}</div>
    {{/hasrows}}
</div>
